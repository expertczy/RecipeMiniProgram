/* ... existing styles ... */

page {
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
  width: 100%;
  height: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  max-width: 750rpx;
  margin: 0 auto;
}

.dish-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.dish-info {
  display: flex;
  align-items: center;
}

.dish-name {
  font-size: 36rpx;
  font-weight: 500;
}

.card-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.card-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.edit-area {
  width: 100%;
  min-height: 120rpx;
  border: 1px solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.5;
}

.save-button {
  background: #07c160 !important;
  color: white;
  border-radius: 8rpx;
  width: 100% !important;
  height: 88rpx;
  font-size: 32rpx;
  display: flex !important;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.delete-button {
  background: #ff4d4f !important;
  color: white;
  border-radius: 8rpx;
  width: 100% !important;
  height: 88rpx;
  font-size: 32rpx;
  display: flex !important;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.save-button::after,
.delete-button::after {
  border: none;
}

.type-tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: white;
}

.type-tag.western {
  background-color: #1890ff;
}

.type-tag.chinese {
  background-color: #ff4d4f;
}

.type-selector {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1px solid #eee;
}

.type-option {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 8rpx;
  border: 1px solid #ddd;
  display: flex;
  justify-content: center;
  align-items: center;
}

.type-icon {
  width: 48rpx;
  height: 48rpx;
}

.type-option.selected {
  background-color: #f0f0f0;
  border-color: #999;
}