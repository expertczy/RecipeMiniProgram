page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.container {
  padding: 20rpx;
  width: 100%;
  height: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.form {
  width: 100%;
  padding: 20rpx;
  box-sizing: border-box;
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.input-row {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.input {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.image-button {
  width: 80rpx !important;
  height: 80rpx;
  padding: 0 !important;
  margin: 0;
  display: flex !important;
  align-items: center;
  justify-content: center;
  background: transparent !important;
}

.icon-wrapper {
  width: 60rpx;
  height: 60rpx;
  border-radius: 6rpx;
  overflow: hidden;
}

.user-icon {
  width: 100%;
  height: 100%;
}

.add-button {
  width: 80rpx !important;
  height: 80rpx;
  border-radius: 8rpx;
  padding: 0 !important;
  margin: 0;
  display: flex !important;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background: #07c160 !important;
  color: white;
}

.add-button::after {
  border: none;
}

.dishes-list {
  width: 100%;
  max-width: 750rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dish-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.dish-content {
  flex: 1;
  margin-right: 20rpx;
}

.dish-name {
  font-size: 32rpx;
  color: #333;
}

.delete-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.delete-btn:active {
  opacity: 0.7;
}

.sync-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  width: 100%;
}

.sync-button {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
  display: flex !important;
  align-items: center;
  justify-content: center;
}

.upload {
  background: #1890ff !important;
  color: white;
}

.download {
  background: #52c41a !important;
  color: white;
}

.sync-button::after {
  border: none;
}

.api-button {
  margin-top: 20rpx;
  width: 100% !important;
  height: 80rpx;
  font-size: 28rpx;
  background: #1890ff !important;
  color: white;
  border-radius: 8rpx;
  display: flex !important;
  align-items: center;
  justify-content: center;
}

.api-button.loading {
  background: #91caff !important;
  opacity: 0.7;
}

.api-button::after {
  border: none;
}