page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.container {
  padding: 20rpx;
  width: 100%;
  height: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.form {
  width: 100%;
  padding: 30rpx;
  box-sizing: border-box;
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.input-row {
  display: flex;
  gap: 20rpx;
  align-items: center;
  min-height: 80rpx;
}

.input {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.image-button {
  width: 80rpx !important;
  height: 80rpx;
  padding: 0 !important;
  margin: 0;
  display: flex !important;
  align-items: center;
  justify-content: center;
  background: #f5f5f5 !important;
  border-radius: 8rpx;
}

.icon-wrapper {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

/* Separate styles for dish card user icon */
.dish-item .user-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

/* Search and filter card icons */
.input-row .user-icon {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-button::after {
  border: none;
}

.add-button {
  width: 80rpx !important;
  height: 80rpx;
  border-radius: 8rpx;
  padding: 0 !important;
  margin: 0;
  display: flex !important;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background: #07c160 !important;
  color: white;
}

.add-button::after {
  border: none;
}

.dishes-list {
  width: 100%;
  max-width: 750rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dish-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.dish-content {
  flex: 1;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.dish-name {
  font-size: 32rpx;
  color: #333;
}

.delete-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  object-fit: cover;
}

.delete-btn:active {
  opacity: 0.7;
}

.sync-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  width: 100%;
}

.sync-button {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
  display: flex !important;
  align-items: center;
  justify-content: center;
}

.upload {
  background: #1890ff !important;
  color: white;
}

.download {
  background: #52c41a !important;
  color: white;
}

.sync-button::after {
  border: none;
}

.api-button {
  margin-top: 20rpx;
  width: 100% !important;
  height: 80rpx;
  font-size: 28rpx;
  background: #1890ff !important;
  color: white;
  border-radius: 8rpx;
  display: flex !important;
  align-items: center;
  justify-content: center;
}

.api-button.loading {
  background: #91caff !important;
  opacity: 0.7;
}

.api-button::after {
  border: none;
}

.icon-group {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.type-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 8rpx;
}

.filter-button {
  width: 80rpx !important;
  height: 80rpx;
  padding: 16rpx !important;
  margin: 0;
  display: flex !important;
  align-items: center;
  justify-content: center;
  background: #f5f5f5 !important;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.filter-button::after, .surprise-button::after {
  border: none;
}

.filter-icon {
  width: 100%;
  height: 100%;
}

.surprise-button {
  font-size: 40rpx;
}

/* Type filter popup styles */
.type-filter-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.type-filter-content {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  width: 80%;
  max-width: 600rpx;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.type-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.type-option.selected {
  background-color: #f0f0f0;
  border-radius: 8rpx;
}

.clear-button {
  width: 100% !important;
  height: 80rpx;
  background: #f5f5f5 !important;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  display: flex !important;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
}

.clear-button::after {
  border: none;
}

.back-button-container {
  padding: 20rpx;
  display: flex;
  justify-content: center;
}

.back-button {
  background-color: #007AFF;
  color: white;
  padding: 20rpx 40rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
}